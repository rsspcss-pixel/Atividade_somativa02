FLOWISE_API_URL="http://flowise:3000/api/v1/prediction/f92dd892-ced9-4396-863b-9675b17242fb"
# Dev local (chatflow sem API key): use local-dev
# Producao / Streamlit Cloud: use a API key criada em Flowise -> API Keys
FLOWISE_API_TOKEN="local-dev"
REQUEST_CONNECT_TIMEOUT_SECONDS=10
REQUEST_READ_TIMEOUT_SECONDS=900
# Prefixo extra no chat (vazio = mais rapido; instrucoes ja estao no agente Flowise)
# CHAT_PROMPT_PREFIX=
DUCKDB_DATABASE_PATH="data/compras.duckdb"
DUCKDB_SOURCE_DIR="data"

# ChromaDB (opcional; pesado — desativado por defeito em producao / Streamlit Cloud)
# CHROMA_ENABLED=0
# OPENAI_API_KEY=sua-chave-aqui
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# CHROMA_PERSIST_DIRECTORY=data/chroma
# CHROMA_COLLECTION_NAME=negociacao_conhecimento
# KNOWLEDGE_TXT_DIR=data/documentos_negociacao

# Guardrails (chat + APIs) — ver docs/guardrails-demo.md
# APP_ENV=demo                    # demo | production (production exige ML_API_TOKEN e EVAL_API_TOKEN)
# GUARDRAILS_ENABLED=1
# GUARDRAILS_MAX_INPUT_CHARS=4000
# GUARDRAILS_BLOCK_INJECTION=1
# GUARDRAILS_BLOCK_ON_PII=0       # 1 = bloqueia em vez de mascarar PII na entrada
# GUARDRAILS_APPEND_DISCLAIMER=1
# GUARDRAILS_RATE_LIMIT=20
# GUARDRAILS_RATE_WINDOW_SECONDS=60
# GUARDRAILS_LINK_ALLOWLIST=empresa.com.br
# ML_API_MAX_QUERY_LEN=200
# EVAL_API_MAX_LIMIT=10
# EVAL_API_ALLOW_BASELINE=0       # 1 = permite save_baseline via API/tool

# =============================================================================
# Deploy no Streamlit Cloud (https://share.streamlit.io) — RECOMENDADO
# =============================================================================
# 1. Repositorio GitHub: rsspcss-pixel/Atividade_somativa02
# 2. Main file path: Flowise/docker/streamlit/app.py
# 3. Secrets (Settings > Secrets):
#    CHAT_BACKEND=openai
#    OPENAI_API_KEY=sk-...
#    OPENAI_CHAT_MODEL=gpt-4o-mini
#    CHROMA_ENABLED=0
# 4. Guia: Flowise/docs/deploy-streamlit-cloud.md
#    Script: cd docker && .\deploy-streamlit-cloud.ps1 -OpenCloud

# DeepEval — judge local LM Studio (2 metricas GEval, execucao serial)
# Configurado no docker-compose (servico streamlit-eval); LM Studio roda no host (porta 1234).
# DEEPEVAL_DRY_RUN=1          # pula Flowise; testa so metricas
# DEEPEVAL_RESULTS_FOLDER=data/deepeval_results
#
# Golden dataset: eval/golden_dataset.json (41 goldens, minimo 31)
#
# Executar evals SOMENTE via Docker (pasta docker/):
#   .\start-stack.ps1          # LM Studio + Flowise + Streamlit
#   .\run-eval.ps1             # avaliacao completa
#   .\run-eval.ps1 -DryRun     # smoke test das metricas (sem Flowise)
#   .\run-eval.ps1 -Build      # rebuild da imagem antes de rodar
#
# Equivalente manual:
#   docker compose --profile eval run --rm streamlit-eval
#
# Modelo ML (UCI Default of Credit Card Clients):
#   python ml/train_model.py
# Artefatos: ml/models/risco_renegociacao.pkl, ml/models/metrics.json
# Aba "ML (risco UCI)" no Streamlit
#
# API ML para agentes Flowise (servico ml-api no docker-compose):
#   ML_API_PORT=8503
#   ML_API_TOKEN=opcional_bearer_para_proteger_a_api
#
# Agente DeepEval Regressao (servico eval-api no docker-compose):
#   EVAL_API_PORT=8504
#   EVAL_API_TOKEN=opcional_bearer_para_proteger_a_api
#   Instalar agente + tool no Flowise:
#     python flowise/install_deepeval_agent.py
#   Smoke test de regressao:
#     .\run-regression-agent.ps1 -Limit 5
#   Avaliacao completa com metrica de regressao:
#     .\run-eval.ps1 -Regression
#
# Importar tools (Flowise -> Tools -> Add Tool):
#   docker/flowise/tools/buscar_insumo_duckdb.json
#   docker/flowise/tools/classificar_risco_renegociacao.json
#   docker/flowise/tools/avaliar_regressao_deepeval.json  (agente DeepEval)

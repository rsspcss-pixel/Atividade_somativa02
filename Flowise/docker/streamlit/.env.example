# =============================================================================
# Streamlit — Assistente de Negociacao (Lumina Cosmetics)
# Copie para .env:  cp .env.example .env
# Secrets Cloud:    .streamlit/secrets.toml (veja secrets.toml.example)
# =============================================================================

# --- Chat (local Docker: Flowise + LM Studio) ---
CHAT_BACKEND=flowise
FLOWISE_API_URL="http://flowise:3000/api/v1/prediction/f92dd892-ced9-4396-863b-9675b17242fb"
# Dev local (chatflow sem API key vinculada no Flowise):
FLOWISE_API_TOKEN="local-dev"
# Se vinculou API key no Flowise UI, use o mesmo valor aqui.

# --- Chat (Streamlit Cloud — recomendado) ---
# CHAT_BACKEND=openai
# OPENAI_API_KEY=sk-...
# OPENAI_CHAT_MODEL=gpt-4o-mini

# --- Timeouts HTTP (chat Flowise / OpenAI) ---
REQUEST_CONNECT_TIMEOUT_SECONDS=10
REQUEST_READ_TIMEOUT_SECONDS=900

# Prefixo extra no prompt (vazio = mais rapido; instrucoes ja estao no agente)
# CHAT_PROMPT_PREFIX=

# --- Dados analiticos (DuckDB + CSVs) ---
DUCKDB_DATABASE_PATH="data/compras.duckdb"
DUCKDB_SOURCE_DIR="data"

# --- ChromaDB (opcional; pesado — desativado por padrao) ---
CHROMA_ENABLED=0
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# CHROMA_PERSIST_DIRECTORY=data/chroma
# CHROMA_COLLECTION_NAME=negociacao_conhecimento
# KNOWLEDGE_TXT_DIR=data/documentos_negociacao

# --- Guardrails (chat + APIs) — ver Flowise/docs/guardrails-demo.md ---
APP_ENV=demo
GUARDRAILS_ENABLED=1
GUARDRAILS_MAX_INPUT_CHARS=4000
GUARDRAILS_BLOCK_INJECTION=1
GUARDRAILS_BLOCK_ON_PII=0
GUARDRAILS_APPEND_DISCLAIMER=1
GUARDRAILS_RATE_LIMIT=20
GUARDRAILS_RATE_WINDOW_SECONDS=60
# GUARDRAILS_LINK_ALLOWLIST=empresa.com.br

# --- APIs auxiliares (Docker Compose) ---
# ML_API_PORT=8503
# ML_API_TOKEN=opcional_bearer
# EVAL_API_PORT=8504
# EVAL_API_TOKEN=opcional_bearer
# EVAL_API_MAX_LIMIT=10
# EVAL_API_ALLOW_BASELINE=0

# --- LM Studio (host; usado pelo Flowise via host.docker.internal:1234) ---
# Modelo padrao: nvidia/nemotron-3-nano-4b (configure-lmstudio-nemotron.ps1 desativa thinking)
# LOCAL_MODEL_NAME=nvidia/nemotron-3-nano-4b
# LM_STUDIO_PORT=1234

# --- DeepEval (profile eval no docker-compose) ---
# DEEPEVAL_DRY_RUN=1
# DEEPEVAL_RESULTS_FOLDER=data/deepeval_results
# Golden dataset: eval/golden_dataset.json (41 casos)
# Testes: python -m pytest test_guardrails.py eval/test_assistente_negociacao.py

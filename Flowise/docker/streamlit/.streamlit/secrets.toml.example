# Copie para secrets.toml (local) ou cole no painel "Secrets" do Streamlit Cloud.
# Nunca commite secrets.toml com valores reais.

FLOWISE_API_URL = "https://seu-flowise.example.com/api/v1/prediction/SEU_CHATFLOW_ID"
FLOWISE_API_TOKEN = "seu-token-flowise"

# Opcional — so necessario se CHROMA_ENABLED = "1" (nao recomendado no Streamlit Cloud)
# CHROMA_ENABLED = "0"
# OPENAI_API_KEY = "sk-..."
# OPENAI_EMBEDDING_MODEL = "text-embedding-3-small"

# Guardrails (opcional)
# APP_ENV = "production"
# GUARDRAILS_ENABLED = "1"
# GUARDRAILS_MAX_INPUT_CHARS = "4000"

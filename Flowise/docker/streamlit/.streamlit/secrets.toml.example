# Copie para secrets.toml (local) ou cole no painel "Secrets" do Streamlit Cloud.
# Nunca commite secrets.toml com valores reais.

# Docker local (via setup-secrets.ps1 a partir do .env):
# FLOWISE_API_URL = "http://flowise:3000/api/v1/prediction/f92dd892-ced9-4396-863b-9675b17242fb"
# FLOWISE_API_TOKEN = "local-dev"

# Streamlit Cloud (Flowise publico na internet):
FLOWISE_API_URL = "https://seu-flowise.example.com/api/v1/prediction/f92dd892-ced9-4396-863b-9675b17242fb"
FLOWISE_API_TOKEN = "seu-token-flowise-ou-local-dev"

CHROMA_ENABLED = "0"
# OPENAI_API_KEY = "sk-..."
# OPENAI_EMBEDDING_MODEL = "text-embedding-3-small"

# Guardrails (opcional)
# APP_ENV = "production"
# GUARDRAILS_ENABLED = "1"
# GUARDRAILS_MAX_INPUT_CHARS = "4000"

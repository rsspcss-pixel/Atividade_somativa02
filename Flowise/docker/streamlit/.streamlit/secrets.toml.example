# Copie para secrets.toml (local) ou cole no painel "Secrets" do Streamlit Cloud.
# Nunca commite secrets.toml com valores reais.

# === LOCAL Docker ===
# FLOWISE_API_URL = "http://flowise:3000/api/v1/prediction/f92dd892-ced9-4396-863b-9675b17242fb"
# FLOWISE_API_TOKEN = "local-dev"

# === Streamlit Cloud (Flowise publico HTTPS) ===
# Gere com: cd Flowise/docker && .\deploy-flowise-public.ps1 -FlowiseUrl "https://SUA-URL.onrender.com" ...
FLOWISE_API_URL = "https://flowise-lumina.onrender.com/api/v1/prediction/f92dd892-ced9-4396-863b-9675b17242fb"
FLOWISE_API_TOKEN = "local-dev"

CHROMA_ENABLED = "0"
REQUEST_CONNECT_TIMEOUT_SECONDS = "15"
REQUEST_READ_TIMEOUT_SECONDS = "120"

# Copie para secrets.toml (local) ou cole no painel "Secrets" do Streamlit Cloud.
# Nunca commite secrets.toml / cloud-secrets.toml com valores reais.

# =============================================================================
# Streamlit Cloud (https://share.streamlit.io) — RECOMENDADO
# =============================================================================
# Main file path: Flowise/docker/streamlit/app.py
# Branch: main

CHAT_BACKEND = "openai"
OPENAI_API_KEY = "sk-..."
OPENAI_CHAT_MODEL = "gpt-4o-mini"
CHROMA_ENABLED = "0"
REQUEST_CONNECT_TIMEOUT_SECONDS = "15"
REQUEST_READ_TIMEOUT_SECONDS = "120"


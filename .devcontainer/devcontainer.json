{
  "name": "Assistente Negociacao",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bookworm",
  "customizations": {
    "codespaces": {
      "openFiles": [
        "README.md",
        "Flowise/docker/streamlit/app.py"
      ]
    },
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },
  "postCreateCommand": "pip install --user -r Flowise/docker/streamlit/requirements.txt",
  "postAttachCommand": "streamlit run Flowise/docker/streamlit/app.py --server.enableCORS false --server.enableXsrfProtection false",
  "forwardPorts": [8501],
  "portsAttributes": {
    "8501": {
      "label": "Streamlit Chat",
      "onAutoForward": "openPreview"
    }
  }
}
